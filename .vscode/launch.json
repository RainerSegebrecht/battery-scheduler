{
  // VS Code launch configurations for battery-scheduler
  // Requires the "Go" extension (golang.go) to be installed.
  //
  // NOTE: In mode "test" VS Code passes "args" directly to the compiled test
  // binary, NOT to "go test". Test flags therefore need the "-test." prefix
  // (e.g. "-test.v" instead of "-v", "-test.run" instead of "-run").
  "version": "0.2.0",
  "configurations": [
    // ──────────────────────────────────────────────────────────────────────────
    // Run all integration tests with the debugger attached
    // ──────────────────────────────────────────────────────────────────────────
    {
      "name": "Integration Tests (all)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/integration",
      "args": ["-test.v", "-test.timeout", "60s"],
      "buildFlags": "-v",
      "env": {
        "CGO_ENABLED": "0",
        "GOTMPDIR": "${env:HOME}/tmp",
        "TZ": "Europe/Berlin"
      },
      "showLog": true
    },

    // ──────────────────────────────────────────────────────────────────────────
    // Debug a single integration test scenario
    // ──────────────────────────────────────────────────────────────────────────
    {
      "name": "Integration: Winter + CheapNight",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/integration",
      "args": ["-test.v", "-test.timeout", "60s", "-test.run", "TestScenario_Winter_CheapNight"],
      "buildFlags": "-v",
      "env": {
        "CGO_ENABLED": "0",
        "GOTMPDIR": "${env:HOME}/tmp",
        "TZ": "Europe/Berlin"
      },
      "showLog": true
    },
    {
      "name": "Integration: Summer (no grid charge)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/integration",
      "args": ["-test.v", "-test.timeout", "60s", "-test.run", "TestScenario_Summer_NoGridCharge"],
      "buildFlags": "-v",
      "env": {
        "CGO_ENABLED": "0",
        "GOTMPDIR": "${env:HOME}/tmp",
        "TZ": "Europe/Berlin"
      },
      "showLog": true
    },
    {
      "name": "Integration: Battery full",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/integration",
      "args": ["-test.v", "-test.timeout", "60s", "-test.run", "TestScenario_BatteryFull"],
      "buildFlags": "-v",
      "env": {
        "CGO_ENABLED": "0",
        "GOTMPDIR": "${env:HOME}/tmp",
        "TZ": "Europe/Berlin"
      },
      "showLog": true
    },
    {
      "name": "Integration: Cheap midday",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/integration",
      "args": ["-test.v", "-test.timeout", "60s", "-test.run", "TestScenario_CheapMidday"],
      "buildFlags": "-v",
      "env": {
        "CGO_ENABLED": "0",
        "GOTMPDIR": "${env:HOME}/tmp",
        "TZ": "Europe/Berlin"
      },
      "showLog": true
    },
    {
      "name": "Integration: All prices expensive",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/integration",
      "args": ["-test.v", "-test.timeout", "60s", "-test.run", "TestScenario_ExpensiveAll"],
      "buildFlags": "-v",
      "env": {
        "CGO_ENABLED": "0",
        "GOTMPDIR": "${env:HOME}/tmp",
        "TZ": "Europe/Berlin"
      },
      "showLog": true
    },
    {
      "name": "Integration: Polling loop",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/integration",
      "args": ["-test.v", "-test.timeout", "60s", "-test.run", "TestScenario_PollingLoop"],
      "buildFlags": "-v",
      "env": {
        "CGO_ENABLED": "0",
        "GOTMPDIR": "${env:HOME}/tmp",
        "TZ": "Europe/Berlin"
      },
      "showLog": true
    },

    // ──────────────────────────────────────────────────────────────────────────
    // Run the main application (requires a config.yaml to exist)
    // ──────────────────────────────────────────────────────────────────────────
    {
      "name": "Run battery-scheduler",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/cmd/battery-scheduler",
      "args": ["-config", "${workspaceFolder}/config/config.yaml"],
      "env": {
        "CGO_ENABLED": "0",
        "GOTMPDIR": "${env:HOME}/tmp",
        "TZ": "Europe/Berlin"
      },
      "showLog": true
    }
  ]
}
